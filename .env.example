# ─── Neural Dream Workshop Environment Variables ───────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── Express Backend ────────────────────────────────────────────────
# PostgreSQL connection string (Neon recommended)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# OpenAI API key for dream analysis and AI chat (GPT-5)
OPENAI_API_KEY=sk-...

# Anthropic API key for morning briefing (POST /api/morning-briefing — claude-haiku-4-5-20251001)
ANTHROPIC_API_KEY=sk-ant-...

# Express session encryption secret (generate a random string)
SESSION_SECRET=change-me-to-a-random-secret

# Server port (default 5000)
PORT=5000

# Node environment
NODE_ENV=development

# ─── Frontend (Vite) ───────────────────────────────────────────────
# ML backend URL (FastAPI) — used by client/src/lib/ml-api.ts
# Development: http://localhost:8000
# Production: set to your Render service URL, e.g. https://neural-dream-ml.onrender.com
# In Vercel deployments, set this via the Vercel dashboard or vercel.json env block.
VITE_ML_API_URL=http://localhost:8000

# Express backend URL — used by client/src/lib/ml-api.ts for brain history endpoints
# Development: leave empty (relative URLs resolve to the same origin)
# Production on Vercel: leave empty if Express runs as Vercel serverless functions
VITE_EXPRESS_URL=

# ─── ML Backend (FastAPI) ──────────────────────────────────────────
# ML server port (default 8000)
ML_PORT=8000

# Log level: DEBUG, INFO, WARNING, ERROR
ML_LOG_LEVEL=INFO

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5000,http://localhost:3000,http://localhost:5173

# ─── Datadog APM / Monitoring ──────────────────────────────────────
# Set DD_AGENT_HOST to enable APM tracing (Node.js + Python backends)
# Leave blank to disable tracing (safe no-op)
DD_AGENT_HOST=
DD_SITE=datadoghq.com
DD_API_KEY=
DD_SERVICE=neural-dream-workshop
DD_ENV=development
DD_VERSION=1.0.0

# Frontend Browser RUM — get these from the Datadog RUM application settings
VITE_DD_APPLICATION_ID=
VITE_DD_CLIENT_TOKEN=
VITE_DD_SITE=datadoghq.com

# ─── Web Push (VAPID) — morning brain report push notifications ───
# Generate keys once with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:your@email.com

# Express → ML backend URL (used for online learner fine-tuning trigger)
ML_BACKEND_URL=http://localhost:8000

# ─── Cloudflare R2 (EEG signal binary storage) ────────────────────
# Leave blank to keep signals on local disk (ml/sessions/*.npz)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=neural-dream-sessions

# Resend (password reset emails)
RESEND_API_KEY=

# ─── Sentry Crash Analytics ─────────────────────────────────────────
# Frontend DSN — get from Sentry project settings → Client Keys (DSN)
VITE_SENTRY_DSN=

# Build-time source map upload (CI only — not needed for local dev)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
