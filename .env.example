# ─── Neural Dream Workshop Environment Variables ───────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── Express Backend ────────────────────────────────────────────────
# PostgreSQL connection string (Neon recommended)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# OpenAI API key for dream analysis and AI chat (GPT-5)
OPENAI_API_KEY=sk-...

# Express session encryption secret (generate a random string)
SESSION_SECRET=change-me-to-a-random-secret

# Server port (default 5000)
PORT=5000

# Node environment
NODE_ENV=development

# ─── Frontend (Vite) ───────────────────────────────────────────────
# ML backend URL (FastAPI)
VITE_ML_API_URL=http://localhost:8000

# ─── ML Backend (FastAPI) ──────────────────────────────────────────
# ML server port (default 8000)
ML_PORT=8000

# Log level: DEBUG, INFO, WARNING, ERROR
ML_LOG_LEVEL=INFO

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5000,http://localhost:3000,http://localhost:5173
